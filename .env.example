# TAMIAS runtime configuration template.
#
# Copy this file to `.env` (or set the variables in your shell / systemd unit
# / Docker compose env / Helm values) to override defaults. None of these are
# required — every value has a sensible default and the app boots without any
# .env file present.
#
# Pick up by `scripts/serve.mjs` automatically because it reads `process.env`.

# Port the static server binds to. If this port is busy, the server will
# automatically walk upward until it finds a free one and print
# `TAMIAS_PORT=<actual port>` to stdout.
PORT=5180

# Network interface to bind. Use 127.0.0.1 to expose the server to loopback
# only (recommended when behind a reverse proxy on the same host).
HOST=0.0.0.0

# NODE_ENV is read by upstream libraries (e.g. React) and should stay
# "production" for deploys.
NODE_ENV=production
